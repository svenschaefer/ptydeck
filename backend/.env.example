NODE_ENV=development
# Required integer 1..65535
PORT=18080
# Required non-empty shell executable name/path
SHELL=bash
# Required non-empty persistence path
DATA_PATH=./data/sessions.json
# Development default: `*`; production should use explicit comma-separated allowlist.
CORS_ORIGIN=*
# Required positive integer
MAX_BODY_BYTES=1048576
# Required positive integer (fixed window size for abuse controls)
RATE_LIMIT_WINDOW_MS=60000
# Required non-negative integer (`0` disables REST create-session rate limit)
RATE_LIMIT_REST_CREATE_MAX=60
# Required non-negative integer (`0` disables WS connect rate limit)
RATE_LIMIT_WS_CONNECT_MAX=60
# Required non-negative integer (`0` disables concurrent session guardrail)
SESSION_MAX_CONCURRENT=0
# Required non-negative integer milliseconds (`0` disables idle-timeout guardrail)
SESSION_IDLE_TIMEOUT_MS=0
# Required non-negative integer milliseconds (`0` disables max-lifetime guardrail)
SESSION_MAX_LIFETIME_MS=0
# Required positive integer milliseconds for guardrail sweep interval
SESSION_GUARDRAIL_SWEEP_MS=1000
# Optional encryption-at-rest (AES-256-GCM):
# DATA_ENCRYPTION_KEYS format: keyId:base64Key,keyId2:base64Key2 (each key 32 bytes before base64)
# DATA_ENCRYPTION_ACTIVE_KEY_ID must reference one configured key id.
DATA_ENCRYPTION_KEYS=
DATA_ENCRYPTION_ACTIVE_KEY_ID=
BACKEND_DEBUG_LOGS=0
BACKEND_DEBUG_LOG_FILE=
# Trusted proxy mode for safe X-Forwarded-* handling:
# off | loopback | all | comma-separated IP list (for example 127.0.0.1,10.0.0.2)
TRUST_PROXY=off
# Enforce TLS-only ingress using trusted forwarded protocol metadata (`1`/`0`).
# Default: `0` in development, `1` in production.
ENFORCE_TLS_INGRESS=0
# Optional auth gate. For now auth is available in development token mode only.
AUTH_ENABLED=0
AUTH_DEV_MODE=0
AUTH_DEV_SECRET=ptydeck-dev-secret
AUTH_ISSUER=ptydeck-dev
AUTH_AUDIENCE=ptydeck-local
AUTH_DEV_TOKEN_TTL_SECONDS=900
